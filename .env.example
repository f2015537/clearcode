# ── LLM ──────────────────────────────────────────────────────────────────────
# Required when llm.provider = "openai" (default)
OPENAI_API_KEY=sk-...

# Required when llm.provider = "anthropic"
# ANTHROPIC_API_KEY=sk-ant-...

# ── Vector store ──────────────────────────────────────────────────────────────
# Required when vector_store.provider = "qdrant"
# Get these from https://cloud.qdrant.io
QDRANT_URL=https://<cluster-id>.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=...

# ── Embeddings ────────────────────────────────────────────────────────────────
# Optional — only needed when embeddings.provider = "huggingface"
# Avoids HuggingFace Hub rate limits on model downloads
# HF_TOKEN=hf_...
